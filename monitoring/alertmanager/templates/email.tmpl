{{ define "email.default.subject" }}{{ if gt (len .Alerts.Firing) 0 }}[{{ (or .CommonLabels.severity "unknown") | toUpper }}] [{{ or .CommonLabels.site "UNKNOWN_SITE" }}] {{ or .CommonAnnotations.summary .CommonLabels.alertname }}{{ else }}[{{ or .CommonLabels.site "UNKNOWN_SITE" }}] 모든 알림이 정상 복구되었습니다.{{ end }}{{ end }}
{{ define "email.default.html" }}
